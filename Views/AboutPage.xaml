<Page
    x:Class="iFlyCompassGUI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels">
    
    <ScrollViewer Background="Transparent">
        <StackPanel Padding="32" Spacing="24" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="关于" FontSize="24" FontWeight="Bold"/>
            
            <Border Background="{StaticResource CardAcrylicBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Text="iFlyCompass GUI" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Opacity="0.7" FontSize="13">
                        <Run Text="应用版本: "/><Run Text="{Binding CurrentAppVersion}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding CurrentVersion, Converter={StaticResource StringFormatConverter}, ConverterParameter='后端版本: {0}'}" Opacity="0.7"/>
                    <TextBlock Text="iFlyCompass 的 Windows 桌面管理工具" Opacity="0.5" FontSize="13"/>
                </StackPanel>
            </Border>
            
            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="后端更新" FontSize="16" FontWeight="SemiBold"/>

                    <StackPanel Spacing="8">
                        <HyperlinkButton Content="GitHub 项目地址"
                                         NavigateUri="https://github.com/MoyuZJ912/iFlyCompass"/>
                    </StackPanel>

                    <StackPanel Spacing="12" Orientation="Horizontal">
                        <Button Content="检查更新" Command="{Binding CheckUpdateCommand}"
                                IsEnabled="{Binding IsChecking, Converter={StaticResource BoolNegationConverter}}"/>
                        <ProgressRing IsActive="{Binding IsChecking}" Width="20" Height="20" VerticalAlignment="Center"/>
                    </StackPanel>

                    <InfoBar IsOpen="{Binding UpdateAvailable}" Severity="Informational"
                             Title="发现后端新版本" Message="{Binding LatestVersion, Converter={StaticResource StringFormatConverter}, ConverterParameter='最新版本: {0}'}"
                             IsClosable="False"/>

                    <StackPanel Spacing="8" Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding UpdateStageText}" FontWeight="SemiBold"/>
                        <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"
                                     ShowError="False" ShowPaused="False"/>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding DownloadSizeText}" Opacity="0.7" FontSize="12"/>
                            <TextBlock Text="{Binding DownloadSpeedText}" Opacity="0.7" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="8" Orientation="Horizontal">
                        <Button Content="更新后端" Command="{Binding PerformUpdateCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                IsEnabled="{Binding IsUpdating, Converter={StaticResource BoolNegationConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <Border Background="{StaticResource CardAcrylicBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="8">
                    <TextBlock Text="开源许可" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="12">
                        本软件基于 WinUI 3 (Windows App SDK) 构建，使用 CommunityToolkit.Mvvm 框架。
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
