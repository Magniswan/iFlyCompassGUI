<Page
    x:Class="iFlyCompassGUI.Views.DisguisePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels"
    IsTabStop="True"
    AllowFocusOnInteraction="True"
    PreviewKeyDown="OnPagePreviewKeyDown"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="24" MaxWidth="720" HorizontalAlignment="Center">

            <!-- 标题区: 伪装为「WinTune Pro」系统优化程序 -->
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <ImageIcon Source="/Assets/WindowIcon.ico" Width="56" Height="56" HorizontalAlignment="Center"/>
                <TextBlock Text="WinTune Pro" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="系统优化 · 加速 · 清理" Opacity="0.6" HorizontalAlignment="Center" FontSize="14"/>
            </StackPanel>

            <!-- 系统状态卡片 -->
            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE9D9;" Foreground="Green" FontSize="22" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="上次优化：片刻前 · 已优化 12 项" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 两个伪装功能卡片 -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D9;" FontSize="22"/>
                            <TextBlock Text="一键清理" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="扫描并清理系统垃圾、缓存与临时文件，释放磁盘空间。" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                        <Button Content="开始清理" Command="{Binding CleanCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="{Binding IsWorking, Converter={StaticResource BoolNegationConverter}}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEC4A;" FontSize="22"/>
                            <TextBlock Text="内存加速" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="结束冗余后台进程，释放内存，提升系统响应速度。" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                        <Button Content="立即加速" Command="{Binding BoostCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="{Binding IsWorking, Converter={StaticResource BoolNegationConverter}}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 进度 (执行中) -->
            <StackPanel Spacing="8"
                        Visibility="{Binding IsWorking, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding WorkingText}" Opacity="0.7" FontSize="13"/>
                <ProgressBar Value="{Binding Progress}" Maximum="100"/>
            </StackPanel>

            <!-- 结果 (完成) -->
            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16"
                    Visibility="{Binding ResultText, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE9D9;" Foreground="Green" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ResultText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 页脚 -->
            <TextBlock Text="© WinTune Pro · 系统优化工具" Opacity="0.4" FontSize="11" HorizontalAlignment="Center"/>

        </StackPanel>
    </ScrollViewer>
</Page>
