<Page
    x:Class="iFlyCompassGUI.Views.InstallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels">

    <Grid Background="Transparent" Padding="40">
        <StackPanel Spacing="32" MaxWidth="720" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- 标题区域 -->
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="安装 iFlyCompass" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding StepName}" FontSize="14" Opacity="0.6" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 主卡片 -->
            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="32">
                <StackPanel Spacing="24">

                    <!-- 下载进度条区域 -->
                    <StackPanel Spacing="8"
                                Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="8"
                                     CornerRadius="4" ShowError="False" ShowPaused="False"/>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding DownloadPercentText}" FontSize="14"
                                       FontWeight="SemiBold" Opacity="0.9"/>
                            <TextBlock Grid.Column="1" Text="{Binding DownloadSizeInfo}" HorizontalAlignment="Center"
                                       FontSize="12" Opacity="0.6"/>
                            <TextBlock Grid.Column="2" Text="{Binding DownloadSpeed}" HorizontalAlignment="Right"
                                       FontSize="12" Opacity="0.6"/>
                        </Grid>
                    </StackPanel>

                    <!-- 步骤指示器 -->
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Step 1 -->
                        <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center" Width="80">
                            <Grid HorizontalAlignment="Center">
                                <Ellipse Width="36" Height="36"
                                         Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=1}"
                                         Opacity="0.15"/>
                                <FontIcon Glyph="&#xE896;" FontSize="16" HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=1}"/>
                            </Grid>
                            <TextBlock Text="下载" FontSize="12" HorizontalAlignment="Center" Opacity="0.8"
                                       FontWeight="{Binding CurrentStep, Converter={StaticResource StepToFontWeightConverter}, ConverterParameter=1}"/>
                        </StackPanel>

                        <!-- Connector 1-2 -->
                        <Rectangle Grid.Column="1" Width="24" Height="2" VerticalAlignment="Top" Margin="0,17,0,0"
                                   Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=2}"
                                   Opacity="0.3"/>

                        <!-- Step 2 -->
                        <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Center" Width="80">
                            <Grid HorizontalAlignment="Center">
                                <Ellipse Width="36" Height="36"
                                         Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=2}"
                                         Opacity="0.15"/>
                                <FontIcon Glyph="&#xE8F1;" FontSize="16" HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=2}"/>
                            </Grid>
                            <TextBlock Text="解压" FontSize="12" HorizontalAlignment="Center" Opacity="0.8"
                                       FontWeight="{Binding CurrentStep, Converter={StaticResource StepToFontWeightConverter}, ConverterParameter=2}"/>
                        </StackPanel>

                        <!-- Connector 2-3 -->
                        <Rectangle Grid.Column="3" Width="24" Height="2" VerticalAlignment="Top" Margin="0,17,0,0"
                                   Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=3}"
                                   Opacity="0.3"/>

                        <!-- Step 3 -->
                        <StackPanel Grid.Column="4" Spacing="6" HorizontalAlignment="Center" Width="80">
                            <Grid HorizontalAlignment="Center">
                                <Ellipse Width="36" Height="36"
                                         Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=3}"
                                         Opacity="0.15"/>
                                <FontIcon Glyph="&#xE895;" FontSize="16" HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=3}"/>
                            </Grid>
                            <TextBlock Text="Python" FontSize="12" HorizontalAlignment="Center" Opacity="0.8"
                                       FontWeight="{Binding CurrentStep, Converter={StaticResource StepToFontWeightConverter}, ConverterParameter=3}"/>
                        </StackPanel>

                        <!-- Connector 3-4 -->
                        <Rectangle Grid.Column="5" Width="24" Height="2" VerticalAlignment="Top" Margin="0,17,0,0"
                                   Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=4}"
                                   Opacity="0.3"/>

                        <!-- Step 4 -->
                        <StackPanel Grid.Column="6" Spacing="6" HorizontalAlignment="Center" Width="80">
                            <Grid HorizontalAlignment="Center">
                                <Ellipse Width="36" Height="36"
                                         Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=4}"
                                         Opacity="0.15"/>
                                <FontIcon Glyph="&#xE912;" FontSize="16" HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=4}"/>
                            </Grid>
                            <TextBlock Text="依赖" FontSize="12" HorizontalAlignment="Center" Opacity="0.8"
                                       FontWeight="{Binding CurrentStep, Converter={StaticResource StepToFontWeightConverter}, ConverterParameter=4}"/>
                        </StackPanel>

                        <!-- Connector 4-5 -->
                        <Rectangle Grid.Column="7" Width="24" Height="2" VerticalAlignment="Top" Margin="0,17,0,0"
                                   Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=5}"
                                   Opacity="0.3"/>

                        <!-- Step 5 -->
                        <StackPanel Grid.Column="8" Spacing="6" HorizontalAlignment="Center" Width="80">
                            <Grid HorizontalAlignment="Center">
                                <Ellipse Width="36" Height="36"
                                         Fill="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=5}"
                                         Opacity="0.15"/>
                                <FontIcon Glyph="&#xE8FB;" FontSize="16" HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{Binding CurrentStep, Converter={StaticResource StepToColorConverter}, ConverterParameter=5}"/>
                            </Grid>
                            <TextBlock Text="完成" FontSize="12" HorizontalAlignment="Center" Opacity="0.8"
                                       FontWeight="{Binding CurrentStep, Converter={StaticResource StepToFontWeightConverter}, ConverterParameter=5}"/>
                        </StackPanel>
                    </Grid>

                    <!-- 详细状态信息 -->
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" Opacity="0.7"
                                   FontSize="13" TextWrapping="Wrap" MaxWidth="560"/>
                        <TextBlock Text="{Binding DepProgress}" HorizontalAlignment="Center" Opacity="0.6"
                                   FontSize="12"
                                   Visibility="{Binding CurrentStep, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=4}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- 操作按钮区域 -->
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <Button Content="进入主页" Command="{Binding NavigateHomeCommand}"
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center" Padding="48,12"
                        Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <StackPanel Spacing="8"
                            Visibility="{Binding IsDownloadFailed, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center">
                    <TextBlock Text="下载失败，请检查网络连接后重试" HorizontalAlignment="Center" Opacity="0.7"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    <Button Content="重试下载" Command="{Binding RetryDownloadCommand}"
                            Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center" Padding="40,12"/>
                </StackPanel>

                <StackPanel Spacing="8"
                            Visibility="{Binding IsFailed, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center">
                    <TextBlock Text="安装失败，请重试或检查系统环境" HorizontalAlignment="Center" Opacity="0.7"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    <Button Content="重新安装" Command="{Binding RetryInstallCommand}"
                            Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center" Padding="40,12"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
