<Page
    x:Class="iFlyCompassGUI.Views.VideoManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels"
    xmlns:models="using:iFlyCompassGUI.Models"
    xmlns:conv="using:iFlyCompassGUI.Converters">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <conv:StringFormatConverter x:Key="StringFormatConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="Transparent" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="视频播放器" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <CommandBar Grid.Row="1" DefaultLabelPosition="Right" Margin="0,0,0,8">
            <AppBarButton Label="导入视频" Command="{Binding ImportVideoCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="导入文件夹" Command="{Binding ImportFolderCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8F4;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="下载视频" Command="{Binding ToggleDownloadPanelCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE896;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="新建文件夹" Command="{Binding CreateFolderCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8F4;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Label="批量转码" Command="{Binding ToggleTranscodePanelCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE950;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="删除选中" Command="{Binding DeleteSelectedVideosCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE74D;"/>
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- 下载面板 -->
        <Border Grid.Row="2" Background="{StaticResource CardAcrylicBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="8" Padding="20" Margin="0,0,0,8"
                Visibility="{Binding IsDownloadPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="下载队列" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="全部取消" Command="{Binding CancelAllDownloadsCommand}"
                            Padding="12,4" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"
                            Visibility="{Binding HasActiveDownloads, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Grid.Column="2" Content="收起" Command="{Binding ToggleDownloadPanelCommand}"
                            Padding="12,4" FontSize="12" VerticalAlignment="Center"/>
                </Grid>

                <!-- 输入区 -->
                <TextBox Header="下载链接" PlaceholderText="输入 HTTP/HTTPS 链接或磁力链接 (magnet:?...)"
                         Text="{Binding DownloadUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <InfoBar IsOpen="{Binding IsBtLink, Mode=OneWay}" Severity="Informational"
                         Title="BT 磁力链接" Message="将使用 aria2c 下载" IsClosable="False"/>

                <!-- 编码 + 画质选择 -->
                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="12">
                    <ComboBox Grid.Column="0" Header="目标编码" ItemsSource="{Binding DownloadCodecOptions}"
                              SelectedItem="{Binding SelectedDownloadCodec, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                    <ComboBox Grid.Column="1" Header="目标画质" ItemsSource="{Binding DownloadQualityPresets}"
                              SelectedItem="{Binding SelectedDownloadQuality, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="2" Content="加入队列" Command="{Binding StartDownloadCommand}"
                            Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom"
                            Padding="16,8"/>
                </Grid>

                <!-- 队列列表 -->
                <ListView ItemsSource="{Binding DownloadTasks}" SelectionMode="None"
                          MaxHeight="300" Padding="0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DownloadTaskItem">
                            <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="6" Padding="12" Margin="0,2">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 第一行：文件名 + 状态标签 + 操作按钮 -->
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="400"
                                                       ToolTipService.ToolTip="{Binding Url}"/>
                                            <Border Background="{ThemeResource ControlStrongFillColorDisabledBrush}"
                                                    CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusBadge}" FontSize="11" Opacity="0.8"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="1" Padding="6,2" Background="Transparent" BorderThickness="0"
                                                Click="OnCancelDownloadTaskClick" Tag="{Binding}">
                                            <FontIcon Glyph="&#xE711;" FontSize="12" Opacity="0.6"/>
                                        </Button>
                                        <Button Grid.Column="2" Padding="6,2" Background="Transparent" BorderThickness="0"
                                                Click="OnRemoveDownloadTaskClick" Tag="{Binding}">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" Opacity="0.6"/>
                                        </Button>
                                    </Grid>

                                    <!-- 第二行：进度条 -->
                                    <ProgressBar Grid.Row="1" Value="{Binding Progress}" Maximum="100" Height="4"
                                                 IsIndeterminate="{Binding IsIndeterminate}"/>

                                    <!-- 第三行：百分比 + 速度 + 大小 -->
                                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,Auto">
                                        <TextBlock Grid.Column="0" FontSize="12" Opacity="0.8"
                                                   Text="{Binding Progress, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:F1}%'}"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Opacity="0.6" Margin="8,0,0,0"
                                                   Text="{Binding SizeText}"
                                                   Visibility="{Binding SizeText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                   Text="{Binding SpeedText}"
                                                   Visibility="{Binding SpeedText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        <TextBlock Grid.Column="3" FontSize="12" Opacity="0.7" Margin="8,0,0,0"
                                                   Text="{Binding EtaText}"
                                                   Visibility="{Binding EtaText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </Grid>

                                    <!-- 第四行：状态 + 节点信息 -->
                                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding StatusText}" Opacity="0.6" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                    Visibility="{Binding PeerInfo, Converter={StaticResource StringToVisibilityConverter}}">
                                            <FontIcon Glyph="&#xE968;" FontSize="10" Opacity="0.6" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PeerInfo}" Opacity="0.6" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 清空已完成按钮 -->
                <Button Content="清空已完成" Command="{Binding ClearCompletedDownloadsCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="12,6" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- 批量转码面板 -->
        <Border Grid.Row="3" Background="{StaticResource CardAcrylicBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="8" Padding="20" Margin="0,0,0,8"
                Visibility="{Binding IsTranscodePanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="批量转码" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="收起" Command="{Binding ToggleTranscodePanelCommand}"
                            Padding="12,4" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="在下方视频列表中勾选要转码的视频，选择编码和画质后点击开始。" Opacity="0.6" FontSize="12"/>
                <Grid ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="12">
                    <ComboBox Grid.Column="0" Header="目标编码" ItemsSource="{Binding TranscodeCodecOptions}"
                              SelectedItem="{Binding SelectedTranscodeCodec, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                    <ComboBox Grid.Column="1" Header="目标画质" ItemsSource="{Binding TranscodeQualityPresets}"
                              SelectedItem="{Binding SelectedTranscodeQuality, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="2" Content="开始转码" Command="{Binding TranscodeSelectedVideosCommand}"
                            Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom" Padding="16,8"/>
                    <Button Grid.Column="3" Content="取消" Command="{Binding CancelTranscodeCommand}"
                            VerticalAlignment="Bottom" Padding="16,8"
                            Visibility="{Binding IsConverting, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 转码进度 -->
        <Border Grid.Row="4" Background="{StaticResource CardAcrylicBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16" Margin="0,0,0,8"
                Visibility="{Binding IsConverting, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding ConversionStatusText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="取消" Command="{Binding CancelTranscodeCommand}"
                            Padding="16,4" FontSize="13" VerticalAlignment="Center"/>
                </Grid>
                <ProgressBar Value="{Binding ConversionProgress}" Maximum="100" Height="8"/>
                <TextBlock Text="{Binding ConversionProgress, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:F1}%'}"
                           Opacity="0.6" FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="5" ColumnDefinitions="280,*">
            <Border Grid.Column="0" Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="8" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="文件夹" FontWeight="SemiBold" FontSize="14" Margin="8,4,8,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="2">
                            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6"
                                    Background="Transparent" BorderThickness="0"
                                    Click="OnRootFolderClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="16"/>
                                    <TextBlock Text="根目录" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding RootVideos.Count, Converter={StaticResource StringFormatConverter}, ConverterParameter='({0})'}"
                                               Opacity="0.5" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <ItemsRepeater ItemsSource="{Binding Folders}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:VideoFolder">
                                        <Grid ColumnDefinitions="*,Auto" Padding="4,2">
                                            <Button Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6"
                                                    Background="Transparent" BorderThickness="0"
                                                    Click="OnFolderClick" Tag="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8F4;" FontSize="16"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Videos.Count, Converter={StaticResource StringFormatConverter}, ConverterParameter='({0})'}"
                                                               Opacity="0.5" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                                <Button Padding="6,2" Background="Transparent" BorderThickness="0"
                                                        Click="OnRenameFolderClick" Tag="{Binding}">
                                                    <FontIcon Glyph="&#xE70F;" FontSize="12" Opacity="0.6"/>
                                                </Button>
                                                <Button Padding="6,2" Background="Transparent" BorderThickness="0"
                                                        Click="OnDeleteFolderClick" Tag="{Binding}">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Opacity="0.6"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding SelectedFolder.Name, FallbackValue='根目录'}"
                               FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding CurrentVideos}"
                              SelectionMode="Multiple" x:Name="VideoListView"
                              SelectionChanged="OnVideoListViewSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:VideoItem">
                                <Grid Padding="4,8" ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                    <FontIcon Grid.Column="0" Glyph="&#xE8B2;" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center" FontSize="14"/>
                                    <Button Grid.Column="2" Content="重命名" FontSize="12" Padding="12,4" Margin="0,0,4,0"
                                            Click="OnRenameVideoClick" Tag="{Binding}"/>
                                    <Button Grid.Column="3" Content="移动" FontSize="12" Padding="12,4" Margin="0,0,4,0"
                                            Click="OnMoveVideoClick" Tag="{Binding}"/>
                                    <Button Grid.Column="4" Content="删除" FontSize="12" Padding="12,4"
                                            Click="OnDeleteVideoClick" Tag="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" Opacity="0.6" Margin="0,8,0,0"/>
    </Grid>
</Page>
