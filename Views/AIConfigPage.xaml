<Page
    x:Class="iFlyCompassGUI.Views.AIConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels">
    
    <ScrollViewer Background="Transparent">
        <StackPanel Padding="32" Spacing="20" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="AI 对话配置" FontSize="24" FontWeight="Bold"/>
            
            <Border Background="{StaticResource CardAcrylicBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock Text="API 设置" FontSize="16" FontWeight="SemiBold"/>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="API Key" FontWeight="SemiBold"/>
                        <PasswordBox Password="{Binding ApiKey, Mode=TwoWay}" Width="400" PlaceholderText="输入 API Key"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="API Base URL" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ApiBaseUrl, Mode=TwoWay}" Width="400" PlaceholderText="https://api.deepseek.com/v1/chat/completions"/>
                    </StackPanel>
                    

                </StackPanel>
            </Border>
            
            <Border Background="{StaticResource CardAcrylicBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock Text="模型参数" FontSize="16" FontWeight="SemiBold"/>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="最大 Token 数" FontWeight="SemiBold"/>
                        <NumberBox Value="{Binding MaxTokens, Mode=TwoWay}" Minimum="100" Maximum="16384" Width="400"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="随机性 (Temperature)" FontWeight="SemiBold"/>
                        <Slider Value="{Binding Temperature, Mode=TwoWay}" Minimum="0" Maximum="2" StepFrequency="0.1" Width="400"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="系统提示词" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SystemPrompt, Mode=TwoWay}" Width="400" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="保存" Command="{Binding SaveConfigCommand}" Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="测试连接" Command="{Binding TestConnectionCommand}" IsEnabled="{Binding IsTesting, Converter={StaticResource BoolNegationConverter}}"/>
                <ProgressRing IsActive="{Binding IsTesting}" Width="20" Height="20" VerticalAlignment="Center"/>
            </StackPanel>
            
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.7"/>
        </StackPanel>
    </ScrollViewer>
</Page>
