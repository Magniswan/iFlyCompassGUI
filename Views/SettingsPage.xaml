<Page
    x:Class="iFlyCompassGUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels">
    
    <ScrollViewer Background="Transparent">
        <StackPanel Padding="32" Spacing="24" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="设置" FontSize="24" FontWeight="Bold"/>
            
            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="启动设置" FontSize="16" FontWeight="SemiBold"/>
                    <ToggleSwitch Header="启动本程序时自动启动 app.py"
                                  IsOn="{Binding AutoStartApp, Mode=TwoWay}"
                                  OnContent="开" OffContent="关"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="窗口设置" FontSize="16" FontWeight="SemiBold"/>
                    <ToggleSwitch Header="记住窗口大小和位置" 
                                  IsOn="{Binding RememberWindowState, Mode=TwoWay}"
                                  OnContent="开" OffContent="关"/>
                </StackPanel>
            </Border>
            
            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="下载源设置" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="选择用于下载 iFlyCompass 的 GitHub 仓库" FontSize="12" Opacity="0.6"/>
                    <ComboBox SelectedItem="{Binding GitHubRepoUrl, Mode=TwoWay}" HorizontalAlignment="Stretch">
                        <x:String>https://github.com/MoyuZJ912/iFlyCompass</x:String>
                        <x:String>https://github.com/Magniswan/iFlyCompass</x:String>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="下载队列设置" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="同时进行的最大下载数量" FontSize="12" Opacity="0.6"/>
                    <NumberBox Value="{Binding MaxConcurrentDownloads, Mode=TwoWay}"
                               Minimum="1" Maximum="10" SmallChange="1" LargeChange="1"
                               SpinButtonPlacementMode="Compact" HorizontalAlignment="Left" Width="120"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="数据管理" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="导入或导出 iFlyCompass/instance/ 目录中的数据（小说、视频等）" FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="导出数据" Command="{Binding ExportInstanceCommand}"
                                IsEnabled="{Binding IsExporting, Converter={StaticResource BoolNegationConverter}}"
                                Style="{StaticResource DefaultButtonStyle}"/>
                        <Button Content="导入数据" Command="{Binding ImportInstanceCommand}"
                                IsEnabled="{Binding IsImporting, Converter={StaticResource BoolNegationConverter}}"
                                Style="{StaticResource DefaultButtonStyle}"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding DataTransferProgress}" Maximum="100" Height="6"
                                 Visibility="{Binding DataTransferStatus, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding DataTransferStatus}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="应用管理" FontSize="16" FontWeight="SemiBold"/>
                    <Button Content="卸载 iFlyCompass" Command="{Binding UninstallCommand}"
                            Style="{StaticResource DefaultButtonStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            IsEnabled="{Binding IsUninstalling, Converter={StaticResource BoolNegationConverter}}"/>
                    <ProgressRing IsActive="{Binding IsUninstalling}" Width="20" Height="20"
                                  HorizontalAlignment="Left"
                                  Visibility="{Binding IsUninstalling, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <Button Content="重置所有设置" Command="{Binding ResetSettingsCommand}"
                    Style="{StaticResource DefaultButtonStyle}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
