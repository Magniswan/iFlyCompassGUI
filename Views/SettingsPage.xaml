<Page
    x:Class="iFlyCompassGUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels">
    
    <ScrollViewer Background="Transparent">
        <StackPanel Padding="32" Spacing="24" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="设置" FontSize="24" FontWeight="Bold"/>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="开机自启" FontSize="16" FontWeight="SemiBold"/>
                    <ToggleSwitch x:Name="AutoStartToggle"
                                  Header="开机静默启动"
                                  IsOn="{Binding IsAutoStartEnabled, Mode=OneWay}"
                                  OnContent="开" OffContent="关"
                                  Toggled="AutoStartToggle_Toggled"/>
                    <TextBlock Text="{Binding AutoStartStatusText}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                    <TextBlock Text="启用后，开机时将以静默方式启动应用与 app.py：不显示窗口、不显示托盘图标，全部在后台运行。再次手动启动程序时会唤出已运行的窗口。" FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="窗口设置" FontSize="16" FontWeight="SemiBold"/>
                    <ToggleSwitch Header="记住窗口大小和位置"
                                  IsOn="{Binding RememberWindowState, Mode=TwoWay}"
                                  OnContent="开" OffContent="关"/>
                    <ToggleSwitch Header="关闭窗口时后台运行"
                                  IsOn="{Binding RunInBackgroundWhenClosed, Mode=TwoWay}"
                                  OnContent="开" OffContent="关"/>
                    <TextBlock Text="开启后，关闭主窗口时应用与 app.py 将隐藏到后台继续运行，不显示任务栏图标；再次启动程序可唤出窗口，如需完全退出请在下方点击「退出 iFlyCompassGUI」。" FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                    <TextBlock Text="未开启此项时，关闭窗口将同时退出应用与 app.py；若此时仍有子进程（app.py、下载、转码等）在运行，会弹出确认对话框询问是否改为后台运行。" FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 暗码设置: 自定义进入真实界面的解锁串 (仅所有者可见，位于暗码门禁之后) -->
            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="暗码设置" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="启动或唤起应用时需键入此暗码才能进入真实界面。留空则使用默认暗码。仅支持字母与数字，大小写不敏感。" FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                    <StackPanel Spacing="8">
                        <TextBlock Text="自定义暗码" FontSize="12" Opacity="0.6"/>
                        <PasswordBox Password="{Binding DarkCode, Mode=TwoWay}"
                                     PlaceholderText="留空使用默认暗码"
                                     PasswordRevealMode="Peek"
                                     HorizontalAlignment="Stretch"/>
                    </StackPanel>
</StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="下载源设置" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="选择用于下载 iFlyCompass 的 GitHub 仓库" FontSize="12" Opacity="0.6"/>
                    <ComboBox SelectedItem="{Binding GitHubRepoUrl, Mode=TwoWay}" HorizontalAlignment="Stretch">
                        <x:String>https://github.com/MoyuZJ912/iFlyCompass</x:String>
                        <x:String>https://github.com/Magniswan/iFlyCompass</x:String>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="下载队列设置" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="同时进行的最大下载数量" FontSize="12" Opacity="0.6"/>
                    <NumberBox Value="{Binding MaxConcurrentDownloads, Mode=TwoWay}"
                               Minimum="1" Maximum="10" SmallChange="1" LargeChange="1"
                               SpinButtonPlacementMode="Compact" HorizontalAlignment="Left" Width="120"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="数据管理" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="导入或导出 iFlyCompass/instance/ 目录中的数据（小说、视频等）" FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="导出数据" Command="{Binding ExportInstanceCommand}"
                                IsEnabled="{Binding IsExporting, Converter={StaticResource BoolNegationConverter}}"
                                Style="{StaticResource DefaultButtonStyle}"/>
                        <Button Content="导入数据" Command="{Binding ImportInstanceCommand}"
                                IsEnabled="{Binding IsImporting, Converter={StaticResource BoolNegationConverter}}"
                                Style="{StaticResource DefaultButtonStyle}"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding DataTransferProgress}" Maximum="100" Height="6"
                                 Visibility="{Binding DataTransferStatus, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding DataTransferStatus}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border x:Name="StorageCard"
                    Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="14">
                    <!-- 头部：标题 + 刷新按钮 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="存储管理" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Command="{Binding RefreshStorageCommand}"
                                    IsEnabled="{Binding IsScanningStorage, Converter={StaticResource BoolNegationConverter}}"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    Padding="10,4" ToolTipService.ToolTip="重新扫描占用">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            </Button>
                            <ProgressRing IsActive="{Binding IsScanningStorage}" Width="16" Height="16"
                                          Visibility="{Binding IsScanningStorage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="查看各类数据占用情况，可清理运行缓存或前往管理界面。app.py 运行时无法清理缓存，请先停止运行。"
                               FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>

                    <!-- 总占用 -->
                    <TextBlock Text="{Binding StorageTotalText}" FontSize="14" Opacity="0.85" FontWeight="SemiBold"/>

                    <!-- 分隔线 -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.5"/>

                    <!-- 分类列表 -->
                    <ItemsControl ItemsSource="{Binding StorageCategories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="13" Opacity="0.7"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="前往" Padding="14,4"
                                                Command="{Binding DataContext.NavigateToManagerCommand, ElementName=StorageCard}"
                                                CommandParameter="{Binding Key}"
                                                Visibility="{Binding Navigable, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Style="{StaticResource DefaultButtonStyle}"/>
                                        <Button Content="清理" Padding="14,4"
                                                Command="{Binding DataContext.CleanCacheCommand, ElementName=StorageCard}"
                                                Visibility="{Binding Cleanable, Converter={StaticResource BoolToVisibilityConverter}}"
                                                IsEnabled="{Binding DataContext.IsCleaningCache, ElementName=StorageCard, Converter={StaticResource BoolNegationConverter}}"
                                                Style="{StaticResource DefaultButtonStyle}"/>
                                        <ProgressRing Width="16" Height="16" IsActive="True"
                                                      Visibility="{Binding DataContext.IsCleaningCache, ElementName=StorageCard, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="应用管理" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="卸载将删除 iFlyCompass 程序文件与内置 Python 环境数据，并自动停止正在运行的 app.py。instance 和 temp 目录中的用户数据会被保留。" FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="卸载 iFlyCompass" Command="{Binding UninstallCommand}"
                                Style="{StaticResource DefaultButtonStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                IsEnabled="{Binding IsUninstalling, Converter={StaticResource BoolNegationConverter}}"/>
                        <Button Content="退出 iFlyCompassGUI" Command="{Binding ExitAppCommand}"
                                Style="{StaticResource DefaultButtonStyle}"/>
                    </StackPanel>
                    <ProgressRing IsActive="{Binding IsUninstalling}" Width="20" Height="20"
                                  HorizontalAlignment="Left"
                                  Visibility="{Binding IsUninstalling, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <Button Content="重置所有设置" Command="{Binding ResetSettingsCommand}"
                    Style="{StaticResource DefaultButtonStyle}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
