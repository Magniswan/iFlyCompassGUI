<Page
    x:Class="iFlyCompassGUI.Views.UserManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels"
    xmlns:models="using:iFlyCompassGUI.Models"
    x:Name="RootGrid">

    <Grid Background="Transparent" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="用户管理" FontSize="24" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="{Binding DbPath}" FontSize="11" Opacity="0.5" Margin="0,0,0,16"
                   Visibility="{Binding IsDbAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Margin="0,0,0,16"
                   Visibility="{Binding IsDbAvailable, Converter={StaticResource BoolNegationToVisibilityConverter}}"/>

        <Grid Grid.Row="2" Margin="0,0,0,16"
              Visibility="{Binding IsDbAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="添加用户" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,Auto,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Header="用户名" Text="{Binding NewUsername, Mode=TwoWay}" PlaceholderText="必填"/>
                <TextBox Grid.Column="1" Header="昵称" Text="{Binding NewNickname, Mode=TwoWay}" PlaceholderText="可选"/>
                <PasswordBox Grid.Column="2" Header="密码" Password="{Binding NewPassword, Mode=TwoWay}" PlaceholderText="至少6位"/>
                <CheckBox Grid.Column="3" Content="管理员" IsChecked="{Binding NewIsAdmin, Mode=TwoWay}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                <Button Grid.Column="4" Content="添加" Command="{Binding AddUserCommand}" VerticalAlignment="Bottom" Style="{StaticResource AccentButtonStyle}"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="3"
              Visibility="{Binding IsDbAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
                <AppBarButton Label="刷新" Command="{Binding LoadUsersCommand}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE72C;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,*,*,Auto,Auto,Auto" Padding="12,8" Background="{StaticResource CardAcrylicBrush}" Margin="0,4,0,0">
                <TextBlock Grid.Column="0" Text="ID" Width="40" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="用户名" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="2" Text="昵称" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="3" Text="角色" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="4" Text="操作" Width="180" FontWeight="SemiBold" FontSize="12"/>
            </Grid>

            <ListView Grid.Row="2" ItemsSource="{Binding Users}" Margin="0,0,0,0"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:UserInfo">
                        <Grid ColumnDefinitions="Auto,*,*,*,Auto,Auto,Auto" Padding="12,8" ColumnSpacing="8">
                            <TextBlock Grid.Column="0" Text="{Binding Id}" Width="40" VerticalAlignment="Center" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding Username}" VerticalAlignment="Center" FontSize="13"/>
                            <TextBlock Grid.Column="2" Text="{Binding Nickname}" VerticalAlignment="Center" FontSize="13" Opacity="0.8"/>
                            <TextBlock Grid.Column="3" Text="{Binding Role}" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <Button Grid.Column="4" Content="编辑" FontSize="12" Padding="8,4"
                                    Click="OnEditUserClick"
                                    Tag="{Binding}"
                                    IsEnabled="{Binding IsSuperAdmin, Converter={StaticResource BoolNegationConverter}}"/>
                            <Button Grid.Column="5" Content="重置密码" FontSize="12" Padding="8,4"
                                    Command="{Binding DataContext.ResetPasswordCommand, ElementName=RootGrid}"
                                    CommandParameter="{Binding}"/>
                            <Button Grid.Column="6" Content="删除" FontSize="12" Padding="8,4"
                                    Command="{Binding DataContext.DeleteUserCommand, ElementName=RootGrid}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding IsSuperAdmin, Converter={StaticResource BoolNegationConverter}}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ProgressRing Grid.Row="2" IsActive="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>
