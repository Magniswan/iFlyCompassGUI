<Page
    x:Class="iFlyCompassGUI.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels">
    
    <Grid Background="Transparent">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24" MaxWidth="600">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="欢迎使用 iFlyCompass" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="一键安装和管理你的 iFlyCompass 服务" Opacity="0.6" HorizontalAlignment="Center" FontSize="14"/>
            </StackPanel>
            
            <Button Content="开始安装" Command="{Binding StartInstallCommand}" 
                    Style="{StaticResource AccentButtonStyle}" 
                    HorizontalAlignment="Center" Padding="48,14" FontSize="18"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource BoolNegationConverter}}"/>
            
            <ProgressRing IsActive="{Binding IsLoading}" HorizontalAlignment="Center" Width="32" Height="32"/>
            
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" Opacity="0.7"/>
                <Button Content="重试" Command="{Binding RetryCommand}" 
                        HorizontalAlignment="Center"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
            
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="最新版本信息" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="{Binding LatestRelease.Name}" FontWeight="Bold" FontSize="14"
                                   Visibility="{Binding LatestRelease, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding RepoUrl}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis"/>
                    <ScrollViewer MaxHeight="200">
                        <TextBlock Text="{Binding LatestRelease.Body}" TextWrapping="Wrap" Opacity="0.8"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
