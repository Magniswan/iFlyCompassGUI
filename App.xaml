<Application
    x:Class="iFlyCompassGUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:iFlyCompassGUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Acrylic Brushes -->
            <AcrylicBrush x:Key="CardAcrylicBrush"
                          TintOpacity="0.6"
                          TintColor="{ThemeResource CardBackgroundFillColorDefault}"
                          FallbackColor="{ThemeResource CardBackgroundFillColorDefault}"/>

            <!-- Converters -->
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <local:BoolNegationConverter x:Key="BoolNegationConverter"/>
            <local:BoolNegationToVisibilityConverter x:Key="BoolNegationToVisibilityConverter"/>
            <local:BoolToBrushConverter x:Key="BoolToBrushConverter" TrueBrush="Green" FalseBrush="Red"/>
            <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
            <local:StepToColorConverter x:Key="StepToColorConverter"/>
            <local:StepToFontWeightConverter x:Key="StepToFontWeightConverter"/>
            <local:BoolToStartStopConverter x:Key="BoolToStartStopConverter"/>
            <local:LevelToColorConverter x:Key="LevelToColorConverter"/>
            <local:StringFormatConverter x:Key="StringFormatConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
