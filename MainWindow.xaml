<Window
    x:Class="iFlyCompassGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iFlyCompassGUI.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="titleBar"
            Title="WinTune Pro"
            IsPaneToggleButtonVisible="False"
            PaneToggleRequested="TitleBar_PaneToggleRequested"
            DoubleTapped="TitleBar_DoubleTapped">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/WindowIcon.ico" />
            </TitleBar.IconSource>
            <TitleBar.LeftHeader>
                <!-- 侧边栏折叠按钮: 仅在真实界面 (已安装且已解锁) 显示；A界面无侧边栏故隐藏。
                     使用 iFly 罗盘图标，与 TitleBar.IconSource 保持一致。 -->
                <Button x:Name="PaneToggleButton"
                        Click="PaneToggleButton_Click"
                        VerticalAlignment="Center"
                        Padding="4"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="{Binding IsMainContentVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Image Source="/Assets/iFlyIcon.ico" Width="16" Height="16" Stretch="Uniform"/>
                </Button>
            </TitleBar.LeftHeader>
        </TitleBar>

        <NavigationView x:Name="NavView"
                      Grid.Row="1"
                      IsPaneOpen="True"
                      IsBackButtonVisible="Collapsed"
                      PaneDisplayMode="Left"
                      IsSettingsVisible="False"
                      Visibility="{Binding IsMainContentVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                      SelectionChanged="NavView_SelectionChanged"
                      OpenPaneLength="220">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="主页" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Content="小说阅读器" Tag="Novel">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE82D;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="视频播放器" Tag="Video">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE714;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="AI 对话配置" Tag="AI">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="用户管理" Tag="Users">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE716;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="日志" Tag="Log">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE90A;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="关于" Tag="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="设置" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <Frame x:Name="WelcomeFrame"
               Grid.Row="1"
               Visibility="{Binding IsWelcomeVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- A界面 (伪装页) 容器: 未解锁时显示，置于最上层以遮挡真实界面 -->
        <Frame x:Name="GateFrame"
               Grid.Row="1"
               Visibility="{Binding IsGateVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</Window>
